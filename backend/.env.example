# ---- Sahm backend configuration (copy to .env for local dev) ----
# NEVER commit a real .env. This file holds placeholders only.

# EODHD financial data API. Token from https://eodhd.com (Settings -> API).
# Needs an active plan that covers the Egyptian Exchange (EGX) for live data.
EODHD_API_TOKEN=your-eodhd-token

# News sentiment LLM (DAILY JOB ONLY — not the web API). Set ONE provider.
# OpenAI is tried first if set, else Anthropic, else free keyword sentiment.
OPENAI_API_TOKEN=
ANTHROPIC_API_TOKEN=

# The single admin account. This email is always admin; everyone else is member.
ADMIN_EMAIL=ahmed.samy@sahm.app

# Database. Local dev defaults to SQLite if unset.
# Prod (Neon): postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=sqlite:///./sahm.db

# Auth. Generate a long random JWT_SECRET for production.
JWT_SECRET=change-me-to-a-long-random-string
# Friends need this code to register an account.
INVITE_CODE=sahm-invite

# CORS: comma-separated origins allowed to call the API (the Vercel site URL).
CORS_ORIGINS=http://localhost:5173

# Exchange + engine knobs (sensible defaults; override only if needed).
EGX_EXCHANGE=EGX
EGX_TOP_N=25
